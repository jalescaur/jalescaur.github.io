---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-rule"></div>
  <div class="footer-inner">
    <span class="footer-name">jales caur</span>
    <span class="footer-copy">© {year} · {t('footer.rights')}</span>
  </div>
</footer>

<style>
  footer { margin-top: 5rem; }

  .footer-rule {
    height: 1px;
    background: var(--rule);
    max-width: 840px;
    margin: 0 auto;
  }

  .footer-inner {
    max-width: 840px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    color: var(--ink-faint);
    letter-spacing: 0.05em;
  }

  .footer-name {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-light);
    letter-spacing: 0.01em;
  }
</style>
