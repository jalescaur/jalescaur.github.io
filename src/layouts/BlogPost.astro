---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    {heroImage && <img class="hero-image" src={heroImage} alt="" />}
    <div class="post-header">
      <span class="eyebrow">Blog</span>
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {updatedDate && (
          <span class="updated">
            · Updated <time datetime={updatedDate.toISOString()}>
              {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </span>
        )}
      </div>
    </div>
    <hr class="rule" />
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .hero-image {
    width: 100%;
    max-height: 360px;
    object-fit: cover;
    border-radius: 2px;
    margin-bottom: 2rem;
  }

  .post-header { padding: 3rem 0 1.5rem; }

  h1 { margin-bottom: 0.75rem; }

  .post-meta {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  .updated { color: var(--ink-faint); }

  .prose {
    max-width: 680px;
    margin-top: 2rem;
  }

  .prose :global(h2) { margin-top: 2.5rem; margin-bottom: 1rem; }
  .prose :global(h3) { margin-top: 2rem; margin-bottom: 0.75rem; }
  .prose :global(p) { margin-bottom: 1.25rem; }
  .prose :global(a) { color: var(--accent); }
  .prose :global(blockquote) {
    border-left: 2px solid var(--rule);
    padding-left: 1.5rem;
    color: var(--ink-light);
    font-style: italic;
    margin: 1.5rem 0;
  }
  .prose :global(pre) {
    background: var(--cream-dark);
    border: 1px solid var(--cream-mid);
    border-radius: 2px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-family: var(--font-sans);
    font-size: 0.875rem;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose :global(li) { margin-bottom: 0.4rem; color: var(--ink-mid); }
</style>