</BaseLayout>

<style>
  .page-header { padding: 3.5rem 0 2rem; }
  h1 { margin-bottom: 0.5rem; }
  .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--ink-light);
    margin-bottom: 1rem;
  }
  .contact-line {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--ink-faint);
    letter-spacing: 0.04em;
  }
  .contact-line a { color: var(--accent); }
  .sep { margin: 0 0.5rem; }

  .cv-block { margin: 2rem 0; }
  h2 { margin-bottom: 1.5rem; }

  .cv-entry {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 0 2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(123, 79, 46, 0.08);
  }
  .cv-entry:last-child { border-bottom: none; }

  .cv-meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    padding-top: 0.2rem;
    text-transform: uppercase;
  }

  .cv-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--ink-mid);
  }
  .cv-body strong { color: var(--ink); font-weight: 600; }
  .cv-body em { color: var(--ink-light); }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 0.5rem;
  }
  .two-col h3 { margin-bottom: 0.75rem; }

  .lang-list, .cert-list {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: var(--ink-mid);
  }
  .lang-list > div { display: flex; gap: 0.75rem; align-items: baseline; }
  .lang-name { color: var(--ink); font-weight: 500; }
  .lang-level { color: var(--ink-faint); font-size: 0.85rem; }

  @media (max-width: 640px) {
    .cv-entry { grid-template-columns: 1fr; gap: 0.25rem; }
    .two-col { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>