---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-photo">
      <img src="/foto.png" alt="Jales Caur" />
    </div>
    <div class="hero-content">
      <span class="eyebrow">IR · Data · Consulting</span>
      <h1>Jales Caur</h1>
      <p class="tagline">Research, teaching and bridges between formal knowledge and the private sector</p>
      <span class="eyebrow">Currently based in Brasília, Brazil</span>
      <div class="hero-body">
        <p>I am a doctoral candidate in International Relations at the University of Brasília (IREL/UnB), investigating planetary politics and the metatheoretical limits of IR as a discipline. I hold degrees in International Relations (UnB) and Data Science (Estácio), and I work as a Political and Data Consultant at BMJ Consultores Associados — leading the BMJ Digital product, which combines data science, OSINT, and discourse analysis.</p>
      </div>
      <div class="hero-links">
        <a href="/research" class="btn-primary">Research →</a>
        <a href="/cv" class="btn-ghost">Curriculum Vitae →</a>
      </div>
      <div class="hero-contact">
        <a href="mailto:contact@jalescaur.com">contact@jalescaur.com</a>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="section-grid">
    <div class="section-label">
      <span class="eyebrow">Current work</span>
    </div>
    <div class="section-content">
      <div class="entry">
        <div class="entry-meta">PhD thesis · IREL/UnB · in progress</div>
        <h3><a href="/research">Planetary Politics: A Beyond for International Relations?</a></h3>
        <p>Advised by Professor Cristina Yumie Aoki Inoue, PhD. Drawing on Lakatos's MSRP to examine whether planetary politics frameworks constitute a genuine metatheoretical shift in IR.</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Consultant · BMJ Consultores Associados · 2024–present</div>
        <h3>BMJ Digital</h3>
        <p>Political analysis and digital risk monitoring — data science, OSINT, and discourse analysis applied to political and sectoral risk intelligence.</p>
        <h3 style="margin-top: 1.25rem;">BMJ Workspace</h3>
        <p>Internal operations platform consolidating political monitoring, CRM, email marketing, legislative tracking, and official gazette feeds. Acted as internal product owner — designing integrations, leading UAT, and filing development requests to replace manual SharePoint workflows with a unified digital workplace.</p>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="section-grid">
    <div class="section-label">
      <span class="eyebrow">Recent output</span>
    </div>
    <div class="section-content">
      <div class="entry">
        <div class="entry-meta">Book review · International Affairs · 2026</div>
        <h3>Review of Ulf Hedetoft, <em>The Morality of Politics: States, Honour and War</em></h3>
        <p>Published in <em>International Affairs</em>, v. 102, p. 712–714.</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Conference paper · 2025</div>
        <h3>Rethinking the 'Global South' Through Complexity Theory in IR</h3>
        <p>Co-authored with B. Lass. Presented at ISA-ABRI Conference, 2025.</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Conference paper · 2025</div>
        <h3>A Mechanic World: The Impact of Newtonian Philosophy on Realist IR Theory</h3>
        <p>Presented at BISA Virtual Conference, 2025.</p>
      </div>
    </div>
  </section>

  <hr class="rule" />

  <section class="section-grid">
    <div class="section-label">
      <span class="eyebrow">Coming soon</span>
    </div>
    <div class="section-content">
      <div class="entry">
        <div class="entry-meta">Conference paper · 2026</div>
        <h3>Planetary Thinking: A New Ontology for International Relations?</h3>
        <p>ISA 2026 Virtual Conference, July 28th</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Conference paper · 2026</div>
        <h3>Befriending the Enemy: Generative Artificial Intelligence on IR Research</h3>
        <p>ISA 2026 Virtual Conference, July 28th</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Conference paper · 2026</div>
        <h3>Fear, Identity and Agency Online: Tracing New International Narratives Through Social Listening and Digital Observation</h3>
        <p>IPSA RC 44 & RC 52 Conference, August 4th</p>
      </div>
      <div class="entry">
        <div class="entry-meta">Book chapter · 2027</div>
        <h3>Interdependence and Concentration: The Political Economy of AI Infrastructure Trade (2021–2024)</h3>
        <p>Co-authored with J. Kreuz. To be published.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 3rem;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .hero-photo {
    position: sticky;
    top: 80px;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top center;
    display: block;
    border-radius: 2px;
    cursor: zoom-in;
  }

  .hero-content { min-width: 0; }

  h1 { margin-bottom: 0.5rem; color: var(--ink); }

  .tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--ink-light);
    margin-bottom: 1.25rem;
    line-height: 1.5;
    display: block;
  }

  .hero-body { margin-bottom: 2rem; }
  .hero-body p { font-size: 1.05rem; }

  .hero-links { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }

  .hero-contact {
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }

  .hero-contact a {
    color: var(--ink-faint);
    text-decoration: none;
    transition: color 0.15s;
  }

  .hero-contact a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .btn-primary {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    color: var(--cream);
    border-radius: 2px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; text-decoration: none; }

  .btn-ghost {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--rule);
    border-radius: 2px;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn-ghost:hover { background: var(--accent-dim); border-color: var(--accent); text-decoration: none; }

  .section-grid {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 0 3rem;
    margin: 2.5rem 0;
  }

  .section-label { padding-top: 0.2rem; }

  .entry { margin-bottom: 2rem; }
  .entry:last-child { margin-bottom: 0; }

  .entry-meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }

  .entry h3 { margin-bottom: 0.4rem; }
  .entry h3 a { color: var(--ink); }
  .entry h3 a:hover { color: var(--accent); text-decoration: none; }
  .entry p { font-size: 0.95rem; }

  @media (max-width: 720px) {
    .hero { grid-template-columns: 1fr; gap: 2rem; }
    .hero-photo { position: static; width: 160px; }
    .section-grid { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>
