<style>
  .page-header { padding: 3.5rem 0 2rem; }
  h1 { margin-bottom: 0; }
  .cv-block { margin: 2rem 0; }
  h2 { margin-bottom: 1.5rem; }

  .thesis-block {
    background: var(--cream-dark);
    border-left: 2px solid var(--accent);
    padding: 2rem 2rem 2rem 2.25rem;
    border-radius: 0 2px 2px 0;
  }

  .thesis-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .thesis-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-style: italic;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .thesis-block p { font-size: 0.95rem; margin-bottom: 0.75rem; }
  .thesis-block p:last-child { margin-bottom: 0; }

  .cv-entry {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0 2rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(123, 79, 46, 0.08);
  }
  .cv-entry:last-child { border-bottom: none; }

  .cv-meta {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    padding-top: 0.2rem;
    text-transform: uppercase;
  }

  .cv-body { font-size: 0.95rem; line-height: 1.7; color: var(--ink-mid); }
  .cv-body strong { color: var(--ink); }

  .areas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .area-tag {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--rule);
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
  }

  .pub-note {
  font-size: 0.8rem;
  color: var(--ink-faint);
  margin-bottom: 1rem;
  }

  @media (max-width: 640px) { .cv-entry { grid-template-columns: 1fr; gap: 0.25rem; } }
</style>
