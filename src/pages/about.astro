---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="page-header">
    <div class="eyebrow">Who I am</div>
    <h1>About</h1>
  </section>

  <div class="about-grid">
    <div class="bio-block">
      <p>Doctoral candidate at <strong>Institute of International Relations of the University of Brasília</strong>, advised by Professor Cristina Yumie Aoki Inoue, PhD. My research sits at the intersection of IR metatheory, planetary politics, and relational ontologies, all in direction of human survivability.</p>
      <p>I hold undergraduate degrees in <strong>International Relations</strong> (UnB) and <strong>Data Science</strong> (Estácio), with an ongoing postgraduate specialization in Statistics at PUC Minas.</p>
      <p>At <strong>BMJ Associated Consultants</strong>, I am a Data & Innovation consultant, and I lead BMJ Digital — a political analysis and digital risk monitoring product combining data science, OSINT, and discourse analysis for Brazilian and international clients.</p>
    </div>

    <div class="aside-block">
      <div class="aside-section">
        <div class="aside-label">Education</div>
        <ul>
          <li>PhD in Internatioanal Relations · Intitute of International Relations, University of Brasília <span class="in-progress">in progress</span></li>
          <li>Postgrad Statistics · PUC Minas <span class="in-progress">ongoing</span></li>
          <li>AAS Data Science · Estácio</li>
          <li>BA International Relations · University of Brasília</li>
        </ul>
      </div>
      <div class="aside-section">
        <div class="aside-label">Links</div>
        <ul>
          <li><a href="https://www.linkedin.com/in/jalescaur/" target="_blank">LinkedIn</a></li>
          <li><a href="http://lattes.cnpq.br/9989811261390202" target="_blank">Lattes CV</a></li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page-header { padding: 3rem 0 2rem; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  h1 { margin-bottom: 0; }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    margin-top: 3rem;
    align-items: start;
  }
  .bio-block p {
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    opacity: 1;
  }
  .bio-block strong { color: var(--color-text); font-weight: 500; }
  .aside-section { margin-bottom: 2rem; }
  .aside-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  ul { list-style: none; }
  li {
    font-size: 0.875rem;
    color: var(--color-muted);
    padding: 0.3rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  li:last-child { border-bottom: none; }
  .in-progress {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-accent);
    margin-left: 0.5rem;
  }
  li a { color: var(--color-muted); }
  li a:hover { color: var(--color-accent); }
  @media (max-width: 720px) {
    .about-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
