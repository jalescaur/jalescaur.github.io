---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog">
  <section class="page-header">
    <span class="eyebrow">Escrita</span>
    <h1>Blog</h1>
  </section>
  <div class="post-list">
    {posts.length === 0 && <p class="empty">Nenhum post ainda — em breve.</p>}
    {posts.map(post => (
      <a href={`/blog/${post.slug}`} class="post-item">
        <div class="post-date">{post.data.pubDate.toLocaleDateString('pt-BR', { year:'numeric', month:'short', day:'numeric' })}</div>
        <div class="post-content">
          <div class="post-title">{post.data.title}</div>
          {post.data.description && <div class="post-desc">{post.data.description}</div>}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
<style>
  .page-header { padding: 3.5rem 0 2rem; }
  h1 { margin-bottom: 0; }
  .post-list { margin-top: 2rem; }
  .post-item { display: grid; grid-template-columns: 110px 1fr; gap: 0 2rem; padding: 1.5rem 0; border-bottom: 1px solid var(--rule); text-decoration: none; }
  .post-item:hover .post-title { color: var(--accent); }
  .post-item:hover { text-decoration: none; }
  .post-date { font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-faint); padding-top: 0.15rem; }
  .post-title { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--ink); transition: color 0.15s; margin-bottom: 0.3rem; }
  .post-desc { font-size: 0.9rem; color: var(--ink-light); }
  .empty { color: var(--ink-faint); font-style: italic; }
</style>
