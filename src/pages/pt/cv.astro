---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Currículo">
  <section class="page-header">
    <span class="eyebrow">Currículo</span>
    <h1>Jales Caur</h1>
    <p class="subtitle">Doutorando em Relações Internacionais · Consultor Político e de Dados</p>
    <div class="contact-line">
      <a href="mailto:contact@jalescaur.com">contact@jalescaur.com</a>
      <span class="sep">·</span>
      <a href="https://www.linkedin.com/in/jalescaur/" target="_blank">LinkedIn</a>
      <span class="sep">·</span>
      <a href="http://lattes.cnpq.br/9989811261390202" target="_blank">Lattes</a>
      <span class="sep">·</span>
      <a href="https://orcid.org/0000-0002-4057-9681" target="_blank">ORCID</a>
    </div>
  </section>

  <hr class="rule" />

  <section class="cv-block">
    <h2>Formação</h2>
